---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const { title, description, date, category, readTime } = frontmatter;

const categoryLabels = {
  learn: 'Learn',
  strategy: 'Strategy',
  variants: 'Variants',
  community: 'Community',
};

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<BaseLayout title={`${title} — Mahjo`} description={description}>
  <div class="article-header">
    <div class="container--narrow">
      <a href={`/${category}`} class={`category-pill category-pill--${category}`}>
        {categoryLabels[category] || category}
      </a>
      <h1 class="article-header__title">{title}</h1>
      <div class="article-header__meta">
        <span>📅 {formattedDate}</span>
        {readTime && <span>⏱ {readTime} min read</span>}
      </div>
    </div>
  </div>

  <div class="container--narrow" style="padding-bottom: 5rem;">
    <article class="prose">
      <slot />
    </article>

    <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(168,137,77,0.2); text-align: center;">
      <p style="color: var(--text3); font-size: 0.9rem; margin-bottom: 1.25rem;">Ready to put this into practice?</p>
      <a href="https://www.mahjo.app" class="btn btn--gold" target="_blank">Play Real Mahjong on Mahjo ↗</a>
    </div>
  </div>
</BaseLayout>
