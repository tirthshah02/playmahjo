---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const { title, description, category, readTime, date, faqs } = frontmatter;

const categoryLabels: Record<string, string> = {
  learn: 'Learn',
  strategy: 'Strategy',
  variants: 'Variants',
  community: 'Community',
};

const allPosts = await Astro.glob('../pages/**/*.md');
const related = allPosts
  .filter(p => p.frontmatter.category === category && p.frontmatter.title !== title)
  .slice(0, 3);

const canonicalUrl = Astro.url.href;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": date,
  "author": {
    "@type": "Organization",
    "name": "Mahjo",
    "url": "https://www.mahjo.app"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mahjo",
    "url": "https://www.mahjo.app"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
});

const faqSchema = faqs && faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: { q: string; a: string }) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
}) : null;

const categoryLabel = categoryLabels[category] || category;
const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://playmahjo.com" },
    { "@type": "ListItem", "position": 2, "name": categoryLabel, "item": `https://playmahjo.com/${category}` },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
});
---
<BaseLayout title={`${title} — Mahjo`} description={description}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={`${title} — Mahjo`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://playmahjo.com/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {date && <meta property="article:published_time" content={new Date(date).toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Mahjo`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://playmahjo.com/og-image.svg" />
    <script type="application/ld+json" set:html={articleSchema} />
    {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <div class="article-header">
    <div class="container--narrow">
      <a href={`/${category}`} class={`category-pill category-pill--${category}`}>
        {categoryLabels[category] || category}
      </a>
      <h1 class="article-header__title">{title}</h1>
      {readTime && (
        <div class="article-header__meta">
          <span>⏱ {readTime} min read</span>
        </div>
      )}
    </div>
  </div>

  <div class="article-layout">
    <div class="article-layout__main">
      <article class="prose">
        <slot />
      </article>

      {faqs && faqs.length > 0 && (
        <div class="article-faq">
          <h2 class="article-faq__heading">Frequently Asked Questions</h2>
          <div class="article-faq__list">
            {faqs.map((faq: { q: string; a: string }) => (
              <div class="article-faq__item">
                <h3 class="article-faq__q">{faq.q}</h3>
                <p class="article-faq__a">{faq.a}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {related.length > 0 && (
        <div class="related-posts">
          <h3 class="related-posts__heading">More in {categoryLabels[category]}</h3>
          <div class="related-posts__grid">
            {related.map(post => (
              <a href={post.url} class="card related-card">
                <h4 class="card__title">{post.frontmatter.title}</h4>
                <p class="card__excerpt">{post.frontmatter.description}</p>
                <span class="card__read-more">Read →</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="article-cta">
        <p class="article-cta__prompt">Ready to put this into practice?</p>
        <a href="https://www.mahjo.app" class="btn btn--gold" target="_blank" data-ga="article_bottom_cta">Play Real Mahjong on Mahjo ↗</a>
      </div>
    </div>

    <aside class="article-toc" id="article-toc" aria-label="Table of contents">
      <p class="article-toc__heading">On this page</p>
      <ol class="article-toc__list" id="toc-list"></ol>
    </aside>
  </div>

  <script>
    (function () {
      const prose = document.querySelector('.prose');
      const tocList = document.getElementById('toc-list');
      const tocSidebar = document.getElementById('article-toc');
      if (!prose || !tocList || !tocSidebar) return;

      // Mid-article CTA after ~halfway through paragraphs (only if article is long enough)
      const paras = Array.from(prose.querySelectorAll('p'));
      if (paras.length >= 6) {
        const insertAfter = paras[Math.floor(paras.length / 2)];
        const mid = document.createElement('div');
        mid.className = 'article-mid-cta';
        mid.innerHTML = `
          <p class="article-mid-cta__text">Want to practice what you're learning?</p>
          <a href="https://www.mahjo.app" class="btn btn--gold" target="_blank" data-ga="mid_cta">Play Mahjo Free ↗</a>
        `;
        insertAfter.insertAdjacentElement('afterend', mid);
      }

      const headings = Array.from(prose.querySelectorAll('h2, h3')) as HTMLElement[];
      if (headings.length < 3) {
        tocSidebar.remove();
        return;
      }

      headings.forEach((h, i) => {
        if (!h.id) {
          const slug = h.textContent!.trim().toLowerCase()
            .replace(/[^\w\s-]/g, '').replace(/[\s_]+/g, '-').replace(/^-+|-+$/g, '');
          h.id = slug || `heading-${i}`;
        }
        const li = document.createElement('li');
        li.className = `article-toc__item article-toc__item--${h.tagName.toLowerCase()}`;
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
      });

      function updateActive() {
        const scrollY = window.scrollY + 110;
        let active = headings[0];
        headings.forEach(h => {
          if (h.getBoundingClientRect().top + window.scrollY <= scrollY) active = h;
        });
        tocList.querySelectorAll('.article-toc__item--active').forEach(el =>
          el.classList.remove('article-toc__item--active')
        );
        if (active) {
          tocList.querySelector(`a[href="#${CSS.escape(active.id)}"]`)
            ?.parentElement?.classList.add('article-toc__item--active');
        }
      }

      window.addEventListener('scroll', updateActive, { passive: true });
      updateActive();
    })();
  </script>
</BaseLayout>

<style>
  .article-faq {
    margin: 3rem 0;
    padding: 2rem;
    background: var(--bg2);
    border: 1px solid rgba(217,179,93,0.2);
    border-radius: 12px;
  }

  .article-faq__heading {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--gold);
  }

  .article-faq__list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .article-faq__item {
    border-bottom: 1px solid rgba(217,179,93,0.12);
    padding-bottom: 1.25rem;
  }

  .article-faq__item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .article-faq__q {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: var(--text);
  }

  .article-faq__a {
    font-size: 0.95rem;
    color: var(--text3);
    margin: 0;
    line-height: 1.65;
  }

  @media (max-width: 680px) {
    .article-faq { padding: 1.5rem 1.25rem; }
    .article-faq__heading { font-size: 1.2rem; }
  }
</style>
