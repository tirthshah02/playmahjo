---
const {
  title = 'Mahjo — The Mahjong Knowledge Hub',
  description = 'Strategy guides, rules, variants, and stories for serious Mahjong players.',
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
const ogImage = 'https://playmahjo.com/og-image.svg';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-KQ06Z6CFQQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-KQ06Z6CFQQ');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Mahjo" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Mahjo RSS Feed" href="/rss.xml" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <slot name="head" />
</head>
<body>
  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Mahjo</a>
      <button class="nav__hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav__links">
        <li><a href="/learn" class={currentPath.startsWith('/learn') ? 'active' : ''}>Learn</a></li>
        <li><a href="/strategy" class={currentPath.startsWith('/strategy') ? 'active' : ''}>Strategy</a></li>
        <li><a href="/variants" class={currentPath.startsWith('/variants') ? 'active' : ''}>Variants</a></li>
        <li><a href="/community" class={currentPath.startsWith('/community') ? 'active' : ''}>Community</a></li>
        <li><a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>All Posts</a></li>
        <li><a href="https://www.mahjo.app" class="nav__cta" target="_blank" data-ga="nav_cta">Play Free ↗</a></li>
      </ul>
    </div>
  </nav>

  <script>
    const hamburger = document.querySelector('.nav__hamburger');
    const navLinks = document.querySelector('.nav__links');
    hamburger?.addEventListener('click', () => {
      const open = navLinks?.classList.toggle('open');
      hamburger.classList.toggle('open', open);
      hamburger.setAttribute('aria-expanded', String(open));
    });
    navLinks?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        hamburger?.classList.remove('open');
        hamburger?.setAttribute('aria-expanded', 'false');
      });
    });

    // GA4 outbound CTA tracking
    document.addEventListener('click', (e) => {
      const el = (e.target as Element).closest('a[href*="mahjo.app"]');
      if (!el || typeof gtag === 'undefined') return;
      const label = (el as HTMLElement).dataset.ga
        || el.className
        || 'unknown';
      gtag('event', 'cta_click', {
        event_category: 'outbound',
        event_label: label,
        page_title: document.title,
      });
    });
  </script>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <span class="footer__logo">Mahjo</span>
    <ul class="footer__links">
      <li><a href="/learn">Learn Mahjong</a></li>
      <li><a href="/strategy">Strategy</a></li>
      <li><a href="/variants">Variants</a></li>
      <li><a href="/community">Community</a></li>
      <li><a href="https://www.mahjo.app" target="_blank" data-ga="footer_cta">Play Mahjo</a></li>
    </ul>
    <p class="footer__copy">© {new Date().getFullYear()} Mahjo. Real Mahjong, online.</p>
  </footer>
</body>
</html>
