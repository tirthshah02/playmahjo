---
const { title = 'Play Mahjo — Learn & Love Mahjong', description = 'Strategy guides, rules, variants, and stories for serious Mahjong players.' } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-KQ06Z6CFQQ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-KQ06Z6CFQQ');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo">Mahjo <span>/ learn mahjong</span></a>
      <ul class="nav__links">
        <li><a href="/learn" class={currentPath.startsWith('/learn') ? 'active' : ''}>Learn</a></li>
        <li><a href="/strategy" class={currentPath.startsWith('/strategy') ? 'active' : ''}>Strategy</a></li>
        <li><a href="/variants" class={currentPath.startsWith('/variants') ? 'active' : ''}>Variants</a></li>
        <li><a href="/community" class={currentPath.startsWith('/community') ? 'active' : ''}>Community</a></li>
        <li><a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>All Posts</a></li>
        <li><a href="https://www.mahjo.app" class="nav__cta" target="_blank">Play Free ↗</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <span class="footer__logo">Mahjo</span>
    <ul class="footer__links">
      <li><a href="/learn">Learn Mahjong</a></li>
      <li><a href="/strategy">Strategy</a></li>
      <li><a href="/variants">Variants</a></li>
      <li><a href="/community">Community</a></li>
      <li><a href="https://www.mahjo.app" target="_blank">Play Mahjo</a></li>
    </ul>
    <p class="footer__copy">© {new Date().getFullYear()} Mahjo. Real Mahjong, online.</p>
  </footer>
</body>
</html>
