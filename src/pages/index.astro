---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('./**/*.md');
const sorted = allPosts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
const featured = sorted[0];
const recent = sorted.slice(1, 7);

const categories = [
  { slug: 'learn', label: 'Learn', icon: '🀄', desc: 'Rules, scoring, and how to play — for beginners and returning players alike.' },
  { slug: 'strategy', label: 'Strategy', icon: '♟️', desc: 'Hand-building theory, reading the table, and thinking several moves ahead.' },
  { slug: 'variants', label: 'Variants', icon: '🌏', desc: 'Hong Kong, American, Riichi, Taiwanese — every major style explained.' },
  { slug: 'community', label: 'Community', icon: '🤝', desc: 'Club spotlights, player stories, and the culture around the tiles.' },
];
---
<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__tiles" aria-hidden="true">
      <span class="hero__tile hero__tile--1">🀇</span>
      <span class="hero__tile hero__tile--2">🀙</span>
      <span class="hero__tile hero__tile--3">🀄</span>
      <span class="hero__tile hero__tile--4">🀅</span>
      <span class="hero__tile hero__tile--5">🀃</span>
    </div>
    <div class="container">
      <span class="hero__eyebrow">The Mahjong knowledge hub</span>
      <h1 class="hero__title">
        Learn the game.<br/>
        <span class="gold">Master the table.</span>
      </h1>
      <p class="hero__subtitle">
        Strategy guides, rules breakdowns, and stories for serious Mahjong players. Written by players, for players.
      </p>
      <div class="hero__actions">
        <a href="/learn" class="btn btn--gold">Start Learning →</a>
        <a href="https://www.mahjo.app" class="btn btn--outline" target="_blank" data-ga="hero_cta">Play Mahjo Free ↗</a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="categories-section">
    <div class="container">
      <div class="category-cards">
        {categories.map(cat => (
          <a href={`/${cat.slug}`} class={`category-card category-card--${cat.slug}`}>
            <span class="category-card__icon">{cat.icon}</span>
            <h3 class="category-card__label">{cat.label}</h3>
            <p class="category-card__desc">{cat.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="home-section">
      <div class="container">
        <div class="section-header">
          <h2>Featured</h2>
        </div>
        <a href={featured.url} class="card card--featured">
          <div class="card__body">
            <div class="card__meta">
              <span class={`category-pill category-pill--${featured.frontmatter.category}`}>
                {featured.frontmatter.category}
              </span>
              {featured.frontmatter.readTime && (
                <span class="card__read-time">⏱ {featured.frontmatter.readTime} min read</span>
              )}
            </div>
            <h2 class="card__title">{featured.frontmatter.title}</h2>
            <p class="card__excerpt">{featured.frontmatter.description}</p>
            <span class="card__read-more">Read article →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Recent posts -->
  {recent.length > 0 && (
    <section class="home-section home-section--spaced">
      <div class="container">
        <div class="section-header">
          <h2>Recent Articles</h2>
          <a href="/blog">View all →</a>
        </div>
        <div class="card-grid">
          {recent.map(post => (
            <a href={post.url} class="card">
              <div class="card__meta">
                <span class={`category-pill category-pill--${post.frontmatter.category}`}>
                  {post.frontmatter.category}
                </span>
                {post.frontmatter.readTime && (
                  <span class="card__read-time">⏱ {post.frontmatter.readTime} min</span>
                )}
              </div>
              <h3 class="card__title">{post.frontmatter.title}</h3>
              <p class="card__excerpt">{post.frontmatter.description}</p>
              <span class="card__read-more">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Play CTA banner -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-banner">
        <h2 class="cta-banner__title">Ready to play real Mahjong?</h2>
        <p class="cta-banner__body">Mahjo is multiplayer Mahjong that actually works — no tile-matching, no shortcuts. Just the real game, online.</p>
        <a href="https://www.mahjo.app" class="btn btn--gold" target="_blank" data-ga="homepage_banner_cta">Play for Free ↗</a>
      </div>
    </div>
  </section>
</BaseLayout>
