---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('../../**/*.md');
const posts = allPosts
  .filter(p => p.frontmatter.category === 'variants')
  .sort((a, b) => (b.frontmatter.readTime || 0) - (a.frontmatter.readTime || 0));

const [featured, ...rest] = posts;
---
<BaseLayout title="Variants — Mahjo" description="Hong Kong, American, Riichi, and more — every style explained.">
  <div class="category-header">
    <div class="container--narrow">
      <span class="category-header__icon">🌏</span>
      <h1>Variants</h1>
      <p style="color: var(--text3); margin-top: 0.75rem;">Hong Kong, American, Riichi, and more — every style explained.</p>
    </div>
  </div>

  <div class="container" style="padding-bottom: 5rem;">
    {posts.length === 0 ? (
      <p class="text-center text-muted" style="padding: 3rem 0;">Articles coming soon.</p>
    ) : (
      <>
        {featured && (
          <a href={featured.url} class="card card--featured card--featured-cat">
            <div class="card__body">
              <div class="card__meta">
                {featured.frontmatter.readTime && (
                  <span class="card__read-time">⏱ {featured.frontmatter.readTime} min read</span>
                )}
              </div>
              <h2 class="card__title">{featured.frontmatter.title}</h2>
              <p class="card__excerpt">{featured.frontmatter.description}</p>
              <span class="card__read-more">Read article →</span>
            </div>
          </a>
        )}
        {rest.length > 0 && (
          <div class="card-grid">
            {rest.map(post => (
              <a href={post.url} class="card">
                <div class="card__meta">
                  {post.frontmatter.readTime && (
                    <span class="card__read-time">⏱ {post.frontmatter.readTime} min</span>
                  )}
                </div>
                <h3 class="card__title">{post.frontmatter.title}</h3>
                <p class="card__excerpt">{post.frontmatter.description}</p>
                <span class="card__read-more">Read →</span>
              </a>
            ))}
          </div>
        )}
      </>
    )}
  </div>
</BaseLayout>
