---
import BaseLayout from '../../layouts/BaseLayout.astro';
const allPosts = await Astro.glob('../../**/*.md');
const posts = allPosts
  .filter(p => p.frontmatter.category === 'strategy')
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
---
<BaseLayout title="Strategy — Mahjo" description="Hand-building theory, table reads, and advanced tactics.">
  <div class="category-header">
    <div class="container--narrow">
      <span class="category-header__icon">♟️</span>
      <h1>Strategy</h1>
      <p style="color: var(--text3); margin-top: 0.75rem;">Hand-building theory, table reads, and advanced tactics.</p>
    </div>
  </div>
  <div class="container" style="padding-bottom: 5rem;">
    {posts.length === 0 ? (
      <p class="text-center text-muted" style="padding: 3rem 0;">Articles coming soon.</p>
    ) : (
      <div class="card-grid">
        {posts.map(post => (
          <a href={post.url} class="card">
            <h3 class="card__title">{post.frontmatter.title}</h3>
            <p class="card__excerpt">{post.frontmatter.description}</p>
            <span class="card__read-more">Read →</span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
